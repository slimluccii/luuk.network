{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "luuk-network",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "secrets": {
    "required": ["DATOCMS_TOKEN"],
  },
}
