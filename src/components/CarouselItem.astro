---
import type { ComponentProps } from "astro/types";
import { Image } from "@datocms/astro";
import Link from "~/components/Link.astro";
import LinkArea from "~/components/LinkArea.astro";

type Props = {
  href: string;
  title: string;
  description: string;
  cover?: ComponentProps<typeof Image>["data"];
  linkLabel?: string;
  meta?: string;
};

const {
  href,
  title,
  linkLabel = "Read more",
  description,
  cover,
  meta,
} = Astro.props;
---

<li class="carousel-item">
  <LinkArea>
    {
      cover && (
        <Image
          pictureClass="carousel-item__cover"
          data={cover}
          imgStyle={{
            width: "100%",
            height: "100%",
            objectFit: "cover",
            maxWidth: "none",
          }}
        />
      )
    }
    <div class="carousel-item__body">
      <div class="carousel-item__text">
          {meta && <p class="carousel-item__meta">{meta}</p>}
          <h3 class="carousel-item__title">{title}</h3>
          <p class="carousel-item__description">{description}</p>
      </div>
      <Link href={href} icon="arrow-right">
        {linkLabel}
        <span class="sr-only"> about {title}</span>
      </Link>
    </div>
  </LinkArea>
</li>

<style>
  .carousel-item {
    flex: 0 0 100%;
    max-inline-size: 22rem;
    scroll-snap-align: center;
  }

  .carousel-item__cover {
    display: block;
    aspect-ratio: 16 / 9;
    inline-size: 100%;
    block-size: auto;
    object-fit: cover;
  }

  .carousel-item__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    border: 1px solid var(--color-surface-raised);
    background-color: var(--color-surface-raised);
    padding: var(--spacing-size-m);
  }

  .carousel-item__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-s);
  }

  .carousel-item__meta {
    opacity: var(--opacity-muted);
    margin: 0;
    font-size: var(--typography-scale-caption);
  }

  .carousel-item__title {
    margin: 0;
  }

  .carousel-item__description {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    margin: 0;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    min-block-size: 3lh;
    overflow: hidden;
  }
</style>
