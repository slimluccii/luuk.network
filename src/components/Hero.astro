---
import Border from "~/components/Border.astro";
---

<Border class="hero">
  <div class="hero__visual">
    <slot name="cover" />
  </div>
  <div class="hero__content">
    <div class="hero-content__top">
      <slot name="subject" />
      <slot name="action" />
    </div>

    <div class="hero-content__bottom">
      <slot />
    </div>
  </div>
</Border>

<style>
  .hero__visual {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;

    &:has(picture)::after {
      position: absolute;
      inset: 0;
      background-color: rgba(0, 0, 0, 0.25);
      pointer-events: none;
      content: "";
    }
  }

  .hero__visual :global(picture) {
    display: block;
    block-size: 100%;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-l);
    background-color: var(--color-surface-base);
    padding: var(--spacing-size-l) var(--spacing-size-l) var(--spacing-size-xxl);
  }

  .hero-content__top {
    display: flex;
    position: relative;
    justify-content: flex-end;
  }

  .hero-content__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight);
  }
</style>

<style is:global>
  .hero__title {
    margin: 0;
    font-weight: 350;
    font-size: var(--typography-scale-display);
    font-family: var(--typography-typeface-heading);
  }

  .hero__meta {
    opacity: var(--opacity-muted);
    margin: 0;
    font-size: var(--typography-scale-caption);
  }
</style>
