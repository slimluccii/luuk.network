---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import Border from "~/components/Border.astro";

interface Props {
  subject: ImageMetadata;
  cover?: ImageMetadata;
}

const { subject, cover } = Astro.props;
---

<Border class="hero">
  <div class="hero__visual">
    {
      cover && (
        <Picture
          class="hero__cover"
          formats={["avif", "webp"]}
          widths={[600, 1200, 1800]}
          sizes="(min-width: 800px) 580px, 100vw"
          src={cover}
          alt=""
          loading="eager"
          fetchpriority="high"
        />
      )
    }
  </div>
  <div class="hero__content">
    <div class="hero-content__top">
      <Picture
        class="hero__image"
        formats={["avif", "webp"]}
        widths={[200, 300, 400, 600]}
        sizes="(min-width: 600px) 200px, (min-width: 400px) 150px, 100px"
        src={subject}
        alt=""
        loading="eager"
        fetchpriority="high"
      />
      <slot name="action" />
    </div>

    <div class="hero-content__bottom">
      <slot />
    </div>
  </div>
</Border>

<style>
  .hero__visual {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;

    &:has(.hero__cover)::after {
      position: absolute;
      inset: 0;
      background-color: rgba(0, 0, 0, 0.25);
      pointer-events: none;
      content: "";
    }
  }

  .hero__visual :global(picture) {
    display: block;
    block-size: 100%;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-l);
    background-color: var(--color-surface-base);
    padding: var(--spacing-size-l) var(--spacing-size-l) var(--spacing-size-xxl);
  }

  .hero-content__top {
    display: flex;
    position: relative;
    justify-content: flex-end;
  }

  .hero-content__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight);
  }
</style>

<style is:global>
  .hero__cover {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .hero__image {
    position: absolute;
    inset-block-end: 0px;
    inset-inline-start: 0px;
    inline-size: 100px;
    block-size: 100px;
    object-fit: cover;

    @media (min-width: 400px) {
      inline-size: 150px;
      block-size: 150px;
    }

    @media (min-width: 600px) {
      inline-size: 200px;
      block-size: 200px;
    }
  }

  .hero__title {
    margin: 0;
    font-weight: 350;
    font-size: var(--typography-scale-display);
    font-family: var(--typography-typeface-heading);
  }

  .hero__meta {
    opacity: 0.75;
    margin: 0;
    font-size: var(--typography-scale-caption);
  }
</style>
