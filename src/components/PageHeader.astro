---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"header">;

const { class: className, ...attrs } = Astro.props;
---

<header class:list={["page-header", className]} {...attrs}>
  <slot />
</header>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-xxs);
    padding-inline: var(--spacing-size-l);
    padding-block: calc(var(--header-height) + var(--spacing-size-l)) 0px;
  }
</style>
