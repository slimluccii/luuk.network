---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div">;

const { class: className, ...attrs } = Astro.props;
---

<div class:list={["prose", className]} {...attrs}>
  <slot />
</div>

<style>
  .prose {
    padding-block: var(--spacing-size-xxl);
  }

  .prose > :global(*) {
    margin-block: 0;
    padding-inline: var(--spacing-size-l);
  }

  .prose > :global(* + *) {
    margin-block-start: var(--spacing-size-m);
  }

  .prose > :global(* + :is(h2, h3)) {
    margin-block-start: var(--spacing-size-xl);
  }

  .prose > :global(:is(h2, h3) + *) {
    margin-block-start: var(--spacing-size-l);
  }

  .prose :global(:is(ul, ol)) {
    padding-inline-start: var(--spacing-size-m);
  }

  .prose :global(li + li) {
    margin-block-start: var(--spacing-size-s);
  }

  .prose :global(blockquote) {
    margin-inline-start: var(--spacing-size-l);
    border-inline-start: 2px solid var(--color-brand-accent);
    padding-inline-start: var(--spacing-size-m);
    font-style: italic;
  }

  .prose :global(blockquote > *) {
    opacity: var(--opacity-muted);
  }

  .prose :global(blockquote > * + *) {
    margin-block-start: var(--spacing-size-m);
  }
</style>
