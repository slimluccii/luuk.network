---
interface Props {
  buttonAttrs?: Record<string, string>;
}

const { buttonAttrs = {} } = Astro.props;
---

<enhanced-button data-button-attrs={JSON.stringify(buttonAttrs)}>
  <slot />
</enhanced-button>

<script>
  class EnhancedButton extends HTMLElement {
    connectedCallback() {
      const anchor = this.querySelector("a");
      if (!anchor) return;

      const extra: Record<string, string> = JSON.parse(
        this.dataset.buttonAttrs || "{}",
      );

      const button = document.createElement("button");
      button.type = "button";

      for (const { name, value } of Array.from(anchor.attributes)) {
        if (name === "href") continue;
        button.setAttribute(name, value);
      }
      for (const [name, value] of Object.entries(extra)) {
        button.setAttribute(name, value);
      }

      button.replaceChildren(...anchor.childNodes);
      anchor.replaceWith(button);
    }
  }

  customElements.define("enhanced-button", EnhancedButton);
</script>

<style>
  enhanced-button {
    display: contents;
  }
</style>
