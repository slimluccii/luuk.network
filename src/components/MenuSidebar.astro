---
import NavList from "~/components/NavList.astro";
import type { MenuItem } from "~/datocms/menu";

interface Props {
  items: MenuItem[];
  currentPageTitle?: string;
}

const { items, currentPageTitle } = Astro.props;
---

{/* Not a landmark: the navigation role lives on the nav wrapper in Base so
    the two viewport-specific menus don't nest duplicate navigation regions. */}
<div class="menu-sidebar">
  <NavList items={items} currentPageTitle={currentPageTitle} showSubList />
</div>

<style>
  /* Wide-viewport affordance only; the drawer replaces it below the
     breakpoint (owned by <ViewportState>). */
  .menu-sidebar {
    display: none;
  }

  :global(html[data-viewport="wide"]) .menu-sidebar {
    display: flex;
    flex: 1;
    align-items: center;
    min-block-size: 0;
  }

  .menu-sidebar :global(.nav-list) {
    flex: 1;
    justify-content: flex-start;
    min-block-size: 0;
    padding: 0;
  }
</style>
