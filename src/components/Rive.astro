---
type RiveFit = "contain" | "cover" | "fill" | "fitWidth" | "fitHeight" | "none";

interface Props {
  src: string;
  stateMachines?: string;
  artboard?: string;
  animations?: string;
  autoplay?: boolean;
  aspectRatio?: string;
  fit?: RiveFit;
  lazy?: boolean;
  class?: string;
}

const {
  src,
  stateMachines,
  artboard,
  animations,
  autoplay = true,
  aspectRatio = "1 / 1",
  fit = "contain",
  lazy = true,
  class: className,
} = Astro.props;
---

<rive-canvas
  data-src={src}
  data-state-machines={stateMachines}
  data-artboard={artboard}
  data-animations={animations}
  data-autoplay={autoplay ? "" : null}
  data-lazy={lazy ? "" : null}
  data-fit={fit}
  class={className}
  style={`--rive-aspect-ratio: ${aspectRatio};`}
>
  <canvas></canvas>
</rive-canvas>

<style>
  rive-canvas {
    display: block;
    aspect-ratio: var(--rive-aspect-ratio, 1 / 1);
    width: 100%;
  }
  rive-canvas canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import type { Rive as RiveType } from "@rive-app/canvas";
  import wasmUrl from "@rive-app/canvas/rive.wasm?url";
  import { observeVisibility } from "~/utils/observe-visibility";

  class RiveCanvas extends HTMLElement {
    rive?: RiveType;
    disconnectVisibility?: () => void;
    resizeObserver?: ResizeObserver;
    started = false;
    inViewport = true;

    connectedCallback() {
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      if (reduceMotion) return;

      document.addEventListener("visibilitychange", this.handleVisibility);

      if (this.dataset.lazy === undefined) {
        this.ensureStarted();
        return;
      }

      this.inViewport = false;
      this.disconnectVisibility = observeVisibility(this, {
        onEnter: () => {
          this.inViewport = true;
          this.ensureStarted();
          this.updatePlayState();
        },
        onLeave: () => {
          this.inViewport = false;
          this.updatePlayState();
        },
      });
    }

    handleVisibility = () => this.updatePlayState();

    ensureStarted() {
      if (this.started) return;
      this.started = true;
      this.start();
    }

    updatePlayState() {
      if (!this.rive) return;
      const shouldPlay = !document.hidden && this.inViewport;
      if (shouldPlay) this.rive.play();
      else this.rive.pause();
    }

    async start() {
      const src = this.dataset.src;
      if (!src) return;

      try {
        const { Rive, RuntimeLoader, Layout, Fit, Alignment } =
          await import("@rive-app/canvas");
        RuntimeLoader.setWasmUrl(wasmUrl);

        const canvas = this.querySelector("canvas")!;
        const fitMap: Record<string, (typeof Fit)[keyof typeof Fit]> = {
          contain: Fit.Contain,
          cover: Fit.Cover,
          fill: Fit.Fill,
          fitWidth: Fit.FitWidth,
          fitHeight: Fit.FitHeight,
          none: Fit.None,
        };
        const fit = fitMap[this.dataset.fit ?? "contain"] ?? Fit.Contain;

        this.rive = new Rive({
          src,
          canvas,
          autoplay: this.dataset.autoplay !== undefined,
          stateMachines: this.dataset.stateMachines,
          artboard: this.dataset.artboard,
          animations: this.dataset.animations,
          layout: new Layout({ fit, alignment: Alignment.Center }),
          onLoad: () => {
            this.rive?.resizeDrawingSurfaceToCanvas();
            this.resizeObserver = new ResizeObserver(() => {
              this.rive?.resizeDrawingSurfaceToCanvas();
            });
            this.resizeObserver.observe(canvas);
            this.updatePlayState();
          },
        });
      } catch (error) {
        console.error("Rive load failed:", error);
      }
    }

    disconnectedCallback() {
      document.removeEventListener("visibilitychange", this.handleVisibility);
      this.disconnectVisibility?.();
      this.resizeObserver?.disconnect();
      this.rive?.cleanup();
    }
  }

  customElements.define("rive-canvas", RiveCanvas);
</script>
