---
import type { ComponentProps } from "astro/types";
import { Image } from "@datocms/astro";

type Props = {
  src: ComponentProps<typeof Image>["data"];
};

const { src } = Astro.props;
---

<Image
  data={src}
  priority
  imgStyle={{
    width: "100%",
    height: "100%",
    objectFit: "cover",
    maxWidth: "none",
  }}
/>
