---
import { getCollection } from "astro:content";
import { levenshtein } from "~/utils/levenshtein";

interface Props {
  limit?: number;
}

const { limit = 5 } = Astro.props;

const referer = Astro.request.headers.get("referer");
const pathname = referer ? new URL(referer).pathname : "";

const projects = await getCollection("projects");

type Route = { href: string; title: string; description: string };

const routes: Route[] = [
  { href: "/", title: "Home", description: "Front-end designer & developer" },
  {
    href: "/projects/",
    title: "Projects",
    description: "An overview of projects I've worked on",
  },
  { href: "/blog/", title: "Blog", description: "Notes and articles" },
  ...projects.map((project) => ({
    href: `/projects/${project.id}/`,
    title: project.data.title,
    description: project.data.description,
  })),
];

const target = pathname.replace(/\/+$/, "").toLowerCase();

const ranked = routes
  .map((route) => ({
    route,
    distance: levenshtein(target, route.href.replace(/\/+$/, "").toLowerCase()),
  }))
  .sort((a, b) => a.distance - b.distance)
  .slice(0, limit)
  .map((entry) => entry.route);
---

{
  pathname && (
    <div class="route-suggestions" aria-label="Suggested pages">
      <p class="route-suggestions__label">Did you mean:</p>
      <ol class="route-suggestions__list">
        {ranked.map((route) => (
          <li class="route-suggestions__item">
            <a href={route.href}>{route.title}</a>
            <p class="route-suggestions__description">{route.description}</p>
            <p class="route-suggestions__path">{route.href}</p>
          </li>
        ))}
      </ol>
    </div>
  )
}

<style is:global>
  .route-suggestions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight);
  }

  .route-suggestions__label {
    margin: 0;
    opacity: 0.75;
    font-size: var(--typography-scale-caption);
  }

  .route-suggestions__list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-l);
    margin: 0;
    padding-inline-start: var(--spacing-size-m);
  }

  .route-suggestions__item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-xxs);
  }

  .route-suggestions__list li::marker {
    opacity: 0.75;
    font-size: var(--typography-scale-caption);
  }

  .route-suggestions__description {
    margin: 0;
  }

  .route-suggestions__path {
    margin: 0;
    opacity: 0.75;
    font-size: var(--typography-scale-caption);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      monospace;
  }

  .route-suggestions__skeleton-item {
    display: block;
    border-radius: 2px;
    background-color: currentColor;
    block-size: 1em;
    opacity: 0.15;
    animation: route-suggestions-pulse 1.4s ease-in-out infinite;
  }

  .route-suggestions__skeleton-item--title {
    inline-size: 9em;
  }

  .route-suggestions__skeleton-item--description {
    inline-size: 16em;
    max-inline-size: 100%;
  }

  .route-suggestions__skeleton-item--path {
    inline-size: 7em;
  }

  @keyframes route-suggestions-pulse {
    0%,
    100% {
      opacity: 0.1;
    }
    50% {
      opacity: 0.25;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .route-suggestions__skeleton-item {
      animation: none;
    }
  }
</style>
