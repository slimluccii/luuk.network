---
import { getCollection } from "astro:content";
import { levenshtein } from "~/utils/levenshtein";

interface Props {
  limit?: number;
}

const { limit = 5 } = Astro.props;

const referer = Astro.request.headers.get("referer");
const pathname = referer ? new URL(referer).pathname : "";

const projects = await getCollection("projects");

type Route = { href: string; title: string };

const routes: Route[] = [
  { href: "/", title: "Home" },
  { href: "/projects/", title: "Projects" },
  { href: "/blog/", title: "Blog" },
  ...projects.map((project) => ({
    href: `/projects/${project.id}/`,
    title: project.data.title,
  })),
];

const target = pathname.replace(/\/+$/, "").toLowerCase();

const ranked = routes
  .map((route) => ({
    route,
    distance: levenshtein(target, route.href.replace(/\/+$/, "").toLowerCase()),
  }))
  .sort((a, b) => a.distance - b.distance)
  .slice(0, limit)
  .map((entry) => entry.route);
---

{
  pathname && (
    <div
      class="route-suggestions"
      aria-live="polite"
      aria-label="Suggested pages"
    >
      <p>Did you mean:</p>
      <ul>
        {ranked.map((route) => (
          <li>
            <a href={route.href}>{route.title}</a>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style is:global>
  .route-suggestions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight);
    min-block-size: calc(
      1.5em * 6 + var(--spacing-gap-tight) * 5
    );
  }

  .route-suggestions ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .route-suggestions__skeleton-item {
    display: block;
    border-radius: 2px;
    background-color: currentColor;
    inline-size: 8em;
    block-size: 1em;
    opacity: 0.15;
    animation: route-suggestions-pulse 1.4s ease-in-out infinite;
  }

  .route-suggestions__skeleton-item:nth-child(2) {
    inline-size: 11em;
  }
  .route-suggestions__skeleton-item:nth-child(3) {
    inline-size: 9em;
  }
  .route-suggestions__skeleton-item:nth-child(4) {
    inline-size: 12em;
  }
  .route-suggestions__skeleton-item:nth-child(5) {
    inline-size: 7em;
  }

  @keyframes route-suggestions-pulse {
    0%,
    100% {
      opacity: 0.1;
    }
    50% {
      opacity: 0.25;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .route-suggestions__skeleton-item {
      animation: none;
    }
  }
</style>
