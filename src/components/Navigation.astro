---
import Border from "~/components/Border.astro";
import Button from "~/components/Button.astro";
import Logo from "~/components/Logo.astro";
import { navLinks } from "~/data/nav";

const { pathname } = Astro.url;
---

<ln-navigation>
  <Button
    class="ln-nav-trigger"
    type="button"
    icon="bars"
    popovertarget="ln-nav-menu"
    aria-controls="ln-nav-menu"
    aria-expanded="false">Menu</Button
  >

  <nav id="ln-nav-menu" popover class="ln-nav-menu" aria-label="Main">
    <Border class="ln-nav-header__border">
      <header class="ln-nav-header">
        <Logo />
      </header>
    </Border>
    <ul class="ln-nav-list">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              class="ln-nav-link"
              href={href}
              aria-current={pathname === href ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <Button
      class="ln-nav-close"
      type="button"
      icon="xmark"
      popovertarget="ln-nav-menu">Close</Button
    >
  </nav>
</ln-navigation>

<script>
  class LnNavigation extends HTMLElement {
    private menu: HTMLElement | null = null;
    private trigger: HTMLButtonElement | null = null;
    private desktopQuery = window.matchMedia("(min-width: 800px)");
    private footerObserver: IntersectionObserver | null = null;

    connectedCallback() {
      this.menu = this.querySelector<HTMLElement>("[popover]");
      this.trigger = this.querySelector<HTMLButtonElement>(".ln-nav-trigger");
      if (!this.menu || !this.trigger) return;

      this.menu.addEventListener("toggle", this.handleToggle);
      this.desktopQuery.addEventListener("change", this.handleMediaChange);

      const footerNav = document.querySelector<HTMLElement>("[data-footer-nav]");
      if (footerNav) {
        this.footerObserver = new IntersectionObserver(
          ([entry]) => {
            this.classList.toggle(
              "ln-nav--footer-visible",
              entry.isIntersecting
            );
          }
        );
        this.footerObserver.observe(footerNav);
      }
    }

    disconnectedCallback() {
      this.menu?.removeEventListener("toggle", this.handleToggle);
      this.desktopQuery.removeEventListener("change", this.handleMediaChange);
      this.footerObserver?.disconnect();
    }

    private handleToggle = (event: Event) => {
      const open = (event as ToggleEvent).newState === "open";
      this.trigger?.setAttribute("aria-expanded", String(open));
      document.documentElement.classList.toggle("ln-nav-scroll-locked", open);
      for (const child of Array.from(document.body.children)) {
        if (!child.contains(this)) {
          (child as HTMLElement).inert = open;
        }
      }
      if (open) {
        this.menu?.querySelector<HTMLElement>(".ln-nav-link")?.focus();
      } else {
        this.trigger?.focus();
      }
    };

    private handleMediaChange = () => {
      if (this.desktopQuery.matches && this.menu?.matches(":popover-open")) {
        this.menu.hidePopover();
      }
    };
  }

  if (!customElements.get("ln-navigation")) {
    customElements.define("ln-navigation", LnNavigation);
  }
</script>

<style is:global>
  html.ln-nav-scroll-locked {
    overflow: hidden;
  }
</style>

<style>
  ln-navigation {
    display: contents;
  }

  .ln-nav-trigger,
  .ln-nav-close {
    position: fixed;
    z-index: 1000;
    inset-block-end: max(var(--spacing-size-l), env(safe-area-inset-bottom));
    inset-inline-end: var(--spacing-size-l);
    transition:
      opacity var(--motion-transition) ease,
      visibility 0s linear 0s;
  }

  .ln-nav-trigger:focus-visible,
  .ln-nav-close:focus-visible,
  .ln-nav-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* Hide the outside trigger while the menu is open. */
  ln-navigation:has(:popover-open) .ln-nav-trigger {
    display: none;
  }

  /* Hide the floating trigger when the footer nav is in view. */
  ln-navigation.ln-nav--footer-visible .ln-nav-trigger {
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--motion-transition) ease,
      visibility 0s linear var(--motion-transition);
  }

  .ln-nav-menu {
    margin: 0;
    /* Override UA centered-modal defaults for full-screen overlay. */
    inset: 0;
    border: 0;
    background-color: var(--color-surface-overlay);
    padding: 0;
    inline-size: 100%;
    max-inline-size: none;
    block-size: 100%;
    max-block-size: none;
    overflow: auto;
    overscroll-behavior: contain;
    color: inherit;
  }

  .ln-nav-menu::backdrop {
    background-color: transparent;
  }

  .ln-nav-list {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    min-block-size: 100%;
    list-style-type: "";
    gap: var(--spacing-size-s);

    @media (min-width: 800px) {
      justify-content: center;
    }
  }

  .ln-nav-link {
    display: block;
    opacity: 0.6;
    transition: var(--motion-feedback) ease;
    color: inherit;
    text-decoration: underline;
    text-decoration-color: transparent;

    &:hover {
      opacity: 1;
      text-decoration-color: currentColor;
    }

    &[aria-current="page"] {
      opacity: 1;
    }
  }

  /* --- Desktop: sidebar --- */

  @media (min-width: 800px) {
    /* Override UA `[popover]:not(:popover-open) { display: none }`.
       Equal specificity (0,2,0); author rule wins by order. */
    .ln-nav-menu:not(:popover-open) {
      display: flex;
    }

    .ln-nav-menu {
      position: sticky;
      align-items: center;
      inset: 0;
      background-color: transparent;
      padding: 0;
      inline-size: auto;
      max-inline-size: none;
      block-size: 100dvh;
      max-block-size: none;
      overflow: visible;
    }

    .ln-nav-list {
      flex: 1;
      justify-content: flex-start;
      min-block-size: 0;
    }

    .ln-nav-trigger,
    .ln-nav-close,
    .ln-nav-header__border {
      display: none;
    }
  }

  .ln-nav-header {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-size-xxs);
  }
</style>
