---
import Button from "~/components/Button.astro";

const { pathname } = Astro.url;
---

<ln-navigation>
  <Button
    class="ln-nav-trigger"
    type="button"
    popovertarget="ln-nav-menu"
    aria-controls="ln-nav-menu"
    aria-expanded="false">Menu</Button>

  <nav id="ln-nav-menu" popover class="ln-nav-menu" aria-label="Main">
    <ul class="ln-nav-list">
      <li>
        <a
          class="ln-nav-link"
          href="/"
          aria-current={pathname === "/" ? "page" : undefined}>Home</a>
      </li>
      <li>
        <a
          class="ln-nav-link"
          href="/blog"
          aria-current={pathname === "/blog" ? "page" : undefined}>Blog</a>
      </li>
      <li>
        <a
          class="ln-nav-link"
          href="/projects"
          aria-current={pathname === "/projects" ? "page" : undefined}
          >Projects</a>
      </li>
    </ul>
    <Button
      class="ln-nav-close"
      type="button"
      popovertarget="ln-nav-menu">Close</Button>
  </nav>
</ln-navigation>

<script>
  class LnNavigation extends HTMLElement {
    private menu: HTMLElement | null = null;
    private trigger: HTMLButtonElement | null = null;
    private desktopQuery = window.matchMedia("(min-width: 800px)");

    connectedCallback() {
      this.menu = this.querySelector<HTMLElement>("[popover]");
      this.trigger = this.querySelector<HTMLButtonElement>(".ln-nav-trigger");
      if (!this.menu || !this.trigger) return;

      this.menu.addEventListener("toggle", this.handleToggle);
      this.desktopQuery.addEventListener("change", this.handleMediaChange);
    }

    disconnectedCallback() {
      this.menu?.removeEventListener("toggle", this.handleToggle);
      this.desktopQuery.removeEventListener("change", this.handleMediaChange);
    }

    private handleToggle = (event: Event) => {
      const open = (event as ToggleEvent).newState === "open";
      this.trigger?.setAttribute("aria-expanded", String(open));
      document.documentElement.classList.toggle("ln-nav-scroll-locked", open);
      for (const child of Array.from(document.body.children)) {
        if (!child.contains(this)) {
          (child as HTMLElement).inert = open;
        }
      }
      if (open) {
        this.menu?.querySelector<HTMLElement>(".ln-nav-link")?.focus();
      } else {
        this.trigger?.focus();
      }
    };

    private handleMediaChange = () => {
      if (this.desktopQuery.matches && this.menu?.matches(":popover-open")) {
        this.menu.hidePopover();
      }
    };
  }

  if (!customElements.get("ln-navigation")) {
    customElements.define("ln-navigation", LnNavigation);
  }
</script>

<style is:global>
  html.ln-nav-scroll-locked {
    overflow: hidden;
  }
</style>

<style>
  ln-navigation {
    display: contents;
  }

  .ln-nav-trigger,
  .ln-nav-close {
    position: fixed;
    inset-block-end: max(var(--spacing-size-m), env(safe-area-inset-bottom));
    inset-inline-end: var(--spacing-size-m);
  }

  .ln-nav-trigger:focus-visible,
  .ln-nav-close:focus-visible,
  .ln-nav-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* Hide the outside trigger while the menu is open. */
  ln-navigation:has(:popover-open) .ln-nav-trigger {
    display: none;
  }

  .ln-nav-menu {
    /* Override UA centered-modal defaults for full-screen overlay. */
    inset: 0;
    margin: 0;
    inline-size: 100dvw;
    block-size: 100dvh;
    max-inline-size: none;
    max-block-size: none;
    border: 0;
    padding: var(--spacing-size-l);
    background-color: var(--color-surface-canvas);
    color: inherit;
    overflow: auto;
    overscroll-behavior: contain;
  }

  .ln-nav-menu::backdrop {
    background-color: transparent;
  }

  .ln-nav-list {
    list-style-type: "";
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-block-size: 100%;
  }

  .ln-nav-link {
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.3em;
    color: inherit;
    padding: var(--spacing-size-s) var(--spacing-size-m);
    display: block;
    opacity: 0.8;
    transition: var(--motion-feedback) ease;

    &:hover {
      opacity: 1;
      text-decoration-color: currentColor;
    }

    &[aria-current="page"] {
      opacity: 1;
    }
  }

  /* --- Desktop: sidebar --- */

  @media (min-width: 800px) {
    /* Override UA `[popover]:not(:popover-open) { display: none }`.
       Equal specificity (0,2,0); author rule wins by order. */
    .ln-nav-menu:not(:popover-open) {
      display: flex;
    }

    .ln-nav-menu {
      position: sticky;
      inset: 0;
      inline-size: auto;
      block-size: 100dvh;
      max-inline-size: none;
      max-block-size: none;
      padding: 0;
      background-color: transparent;
      overflow: visible;
      align-items: center;
    }

    .ln-nav-list {
      flex: 1;
      min-block-size: 0;
      justify-content: flex-start;
    }

    .ln-nav-link {
      padding: var(--spacing-size-xs) var(--spacing-size-m);
    }

    .ln-nav-trigger,
    .ln-nav-close {
      display: none;
    }
  }
</style>
