---
import Border from "~/components/Border.astro";
import Button from "~/components/Button.astro";
import Logo from "~/components/Logo.astro";
import NavList from "~/components/NavList.astro";

interface Props {
  currentPageTitle?: string;
}

const { currentPageTitle } = Astro.props;
---

<ln-navigation>
  <Button
    class="ln-nav-trigger"
    type="button"
    icon="menu"
    popovertarget="ln-nav-menu"
    aria-controls="ln-nav-menu"
    aria-expanded="false">Menu</Button
  >

  <nav id="ln-nav-menu" popover class="ln-nav-menu" aria-label="Main">
    <Border class="ln-nav-header__border">
      <header class="ln-nav-header">
        <Logo />
      </header>
    </Border>
    <NavList currentPageTitle={currentPageTitle} showSubList />
    <Button
      class="ln-nav-close"
      type="button"
      icon="x"
      popovertarget="ln-nav-menu">Close</Button
    >
  </nav>
</ln-navigation>

<script>
  const DESKTOP_QUERY = "(min-width: 800px)";
  const FOOTER_NAV_SELECTOR = "[data-footer-nav]";
  const SCROLL_LOCK_CLASS = "ln-nav-scroll-locked";
  const FOOTER_VISIBLE_CLASS = "ln-nav--footer-visible";

  /** Make every direct child of <body> (except this element's branch) inert. */
  function setSiblingsInert(self: HTMLElement, inert: boolean) {
    for (const child of document.body.children) {
      if (!child.contains(self)) {
        (child as HTMLElement).inert = inert;
      }
    }
  }

  class LnNavigation extends HTMLElement {
    private menu!: HTMLElement;
    private trigger!: HTMLButtonElement;
    private desktopQuery = window.matchMedia(DESKTOP_QUERY);
    private footerObserver: IntersectionObserver | null = null;

    connectedCallback() {
      const menu = this.querySelector<HTMLElement>("[popover]");
      const trigger = this.querySelector<HTMLButtonElement>(".ln-nav-trigger");
      if (!menu || !trigger) return;
      this.menu = menu;
      this.trigger = trigger;

      this.menu.addEventListener("toggle", this.handlePopoverToggle);
      this.desktopQuery.addEventListener("change", this.handleViewportChange);
      this.observeFooter();
    }

    disconnectedCallback() {
      this.menu?.removeEventListener("toggle", this.handlePopoverToggle);
      this.desktopQuery.removeEventListener(
        "change",
        this.handleViewportChange
      );
      this.footerObserver?.disconnect();
    }

    /** Sync side effects whenever the popover opens or closes. */
    private handlePopoverToggle = (event: Event) => {
      const open = (event as ToggleEvent).newState === "open";

      this.trigger.setAttribute("aria-expanded", String(open));
      document.documentElement.classList.toggle(SCROLL_LOCK_CLASS, open);
      setSiblingsInert(this, open);

      const focusTarget = open
        ? this.menu.querySelector<HTMLElement>(".nav-list__link")
        : this.trigger;
      focusTarget?.focus();
    };

    /** On resize to desktop, the popover should never stay open. */
    private handleViewportChange = () => {
      if (this.desktopQuery.matches && this.menu.matches(":popover-open")) {
        this.menu.hidePopover();
      }
    };

    /** Hide the floating trigger when the footer nav is visible. */
    private observeFooter() {
      const footerNav =
        document.querySelector<HTMLElement>(FOOTER_NAV_SELECTOR);
      if (!footerNav) return;

      this.footerObserver = new IntersectionObserver(([entry]) => {
        this.classList.toggle(FOOTER_VISIBLE_CLASS, entry.isIntersecting);
      });
      this.footerObserver.observe(footerNav);
    }
  }

  if (!customElements.get("ln-navigation")) {
    customElements.define("ln-navigation", LnNavigation);
  }
</script>

<style is:global>
  html.ln-nav-scroll-locked {
    overflow: hidden;
  }
</style>

<style>
  /* --- Root ----------------------------------------------------------- */

  ln-navigation {
    display: contents;
  }

  /* --- Floating buttons (mobile trigger + close) ---------------------- */

  .ln-nav-trigger,
  .ln-nav-close {
    position: fixed;
    z-index: 1000;
    inset-block-end: max(var(--spacing-size-l), env(safe-area-inset-bottom));
    inset-inline-end: var(--spacing-size-l);
  }

  /* Hide the outside trigger while the menu is open. */
  ln-navigation:has(:popover-open) .ln-nav-trigger {
    display: none;
  }

  /* Fade the floating trigger out while the footer nav is in view.
     Visibility flips instantly when showing, but waits for the fade
     when hiding so the button stays focusable until it's gone. */
  .ln-nav-trigger {
    transition:
      opacity var(--motion-transition) ease,
      visibility 0s linear 0s;
  }

  ln-navigation.ln-nav--footer-visible .ln-nav-trigger {
    visibility: hidden;
    opacity: 0;
    transition:
      opacity var(--motion-transition) ease,
      visibility 0s linear var(--motion-transition);
  }

  /* --- Focus ---------------------------------------------------------- */

  .ln-nav-trigger:focus-visible,
  .ln-nav-close:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* --- Mobile menu (full-screen popover) ------------------------------ */

  .ln-nav-menu {
    /* Override UA centered-modal defaults for full-screen overlay. */
    margin: 0;
    inset: 0;
    border: 0;
    background-color: var(--color-surface-overlay);
    padding: 0;
    inline-size: 100dvw;
    max-inline-size: none;
    block-size: 100dvh;
    max-block-size: none;
    overflow-x: clip;
    overflow-y: auto;
    overscroll-behavior: contain;
    color: inherit;
  }

  .ln-nav-menu::backdrop {
    background-color: transparent;
  }

  .ln-nav-menu :global(.nav-list) {
    padding: var(--spacing-size-l);
  }

  /* --- Header (logo, mobile only) ------------------------------------- */

  .ln-nav-header {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-size-xxs);
  }

  /* --- Desktop: sticky sidebar ---------------------------------------- */

  @media (min-width: 800px) {
    /* Override UA `[popover]:not(:popover-open) { display: none }`.
       Equal specificity (0,2,0); author rule wins by order. */
    .ln-nav-menu:not(:popover-open) {
      display: flex;
    }

    .ln-nav-menu {
      position: sticky;
      align-items: center;
      inset: 0;
      background-color: transparent;
      padding: 0;
      inline-size: auto;
      max-inline-size: none;
      block-size: 100dvh;
      max-block-size: none;
      overflow: visible;
    }

    .ln-nav-menu :global(.nav-list) {
      flex: 1;
      justify-content: flex-start;
      padding: 0;
      min-block-size: 0;
    }

    .ln-nav-trigger,
    .ln-nav-close,
    .ln-nav-header__border {
      display: none;
    }
  }
</style>
