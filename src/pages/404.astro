---
import Base from "~/layouts/Base.astro";
import Button from "~/components/Button.astro";
import PageHeader from "~/components/PageHeader.astro";
import RouteSuggestions from "~/components/RouteSuggestions.astro";
import Section from "~/components/Section.astro";
import SectionActions from "~/components/SectionActions.astro";
import SectionContent from "~/components/SectionContent.astro";
import SectionTitle from "~/components/SectionTitle.astro";

const seo = {
  title: "Not Found",
  description: "The page you're looking for doesn't exist.",
};
---

<Base seo={seo}>
  <PageHeader>
    <h1>Not Found</h1>
  </PageHeader>
  <Section>
    <SectionContent>
      <p>The page you're looking for doesn't exist.</p>
    </SectionContent>
    <SectionActions>
      <Button as="a" icon="arrow-left" href="/">Back to home</Button>
    </SectionActions>
    <SectionTitle>Did you mean</SectionTitle>
    <RouteSuggestions server:defer>
      <div
        slot="fallback"
        class="route-suggestions"
        aria-busy="true"
        aria-live="polite"
      >
        <p class="route-suggestions__status">
          Looking for similar pages...
        </p>
        <ol class="route-suggestions__list" aria-hidden="true">
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
        </ol>
      </div>
    </RouteSuggestions>
  </Section>
</Base>
