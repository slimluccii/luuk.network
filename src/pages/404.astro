---
import Base from "~/layouts/Base.astro";
import PageHeader from "~/components/PageHeader.astro";
import PageHeaderEyebrow from "~/components/PageHeaderEyebrow.astro";
import RouteSuggestions from "~/components/RouteSuggestions.astro";

const seo = {
  title: "Page not found",
  description: "The page you're looking for doesn't exist.",
};
---

<Base seo={seo}>
  <article class="error-state">
    <PageHeader>
      <PageHeaderEyebrow>404</PageHeaderEyebrow>
      <h1 class="error-state__title">Page not found</h1>
    </PageHeader>
    <div class="error-state__body">
      <p>The page you're looking for doesn't exist.</p>
      <RouteSuggestions server:defer>
        <div
          slot="fallback"
          class="route-suggestions"
          aria-busy="true"
          aria-live="polite"
        >
          <p class="route-suggestions__label">Looking for similar pages...</p>
          <ol class="route-suggestions__list" aria-hidden="true">
            {[0, 1, 2, 3, 4].map(() => (
              <li>
                <div class="route-suggestions__item">
                  <span class="route-suggestions__skeleton-item route-suggestions__skeleton-item--title" />
                  <span class="route-suggestions__skeleton-item route-suggestions__skeleton-item--description" />
                  <span class="route-suggestions__skeleton-item route-suggestions__skeleton-item--path" />
                </div>
              </li>
            ))}
          </ol>
        </div>
      </RouteSuggestions>
    </div>
  </article>
</Base>

<style>
  .error-state {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    padding-block-end: var(--spacing-size-xxl);
  }

  .error-state__title {
    margin: 0;
    font-weight: 400;
    font-size: var(--typography-scale-heading);
    font-family: var(--typography-typeface-body);
  }

  .error-state__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    padding-inline: var(--spacing-size-l);
  }

  .error-state__body p {
    margin: 0;
  }
</style>
