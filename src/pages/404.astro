---
import Base from "~/layouts/Base.astro";
import RouteSuggestions from "~/components/RouteSuggestions.astro";

const seo = {
  title: "Page not found",
  description: "The page you're looking for doesn't exist.",
};
---

<Base seo={seo}>
  <article class="error-state">
    <header class="error-state__header">
      <p class="error-state__code">404</p>
      <h1 class="error-state__title">Page not found</h1>
    </header>
    <p>The page you're looking for doesn't exist.</p>
    <RouteSuggestions server:defer>
      <div
        slot="fallback"
        class="route-suggestions"
        aria-busy="true"
        aria-live="polite"
      >
        <p class="route-suggestions__label">Looking for similar pages...</p>
        <ol class="route-suggestions__list" aria-hidden="true">
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
          <li><span class="route-suggestions__skeleton-item" /></li>
        </ol>
      </div>
    </RouteSuggestions>
  </article>
</Base>

<style>
  .error-state {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    padding: calc(var(--ln-header-height) + var(--spacing-size-xl))
      var(--spacing-size-l) var(--spacing-size-xxl);
  }

  .error-state__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-xxs);
  }

  .error-state__code {
    margin: 0;
    opacity: 0.75;
    font-size: var(--typography-scale-caption);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .error-state__title {
    margin: 0;
    font-weight: 400;
    font-size: var(--typography-scale-heading);
    font-family: var(--typography-typeface-body);
  }

  .error-state p {
    margin: 0;
  }
</style>
