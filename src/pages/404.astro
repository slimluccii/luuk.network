---
import Base from "~/layouts/Base.astro";
import Button from "~/components/Button.astro";
import EmptyState from "~/components/EmptyState.astro";
import PageHeader from "~/components/PageHeader.astro";
import RouteSuggestions from "~/components/RouteSuggestions.astro";
import Section from "~/components/Section.astro";

const seo = {
  title: "Not Found",
  description: "The page you're looking for doesn't exist.",
};
---

<Base seo={seo}>
  <PageHeader>
    <h1>Not Found</h1>
  </PageHeader>
  <Section>
    <EmptyState>
      <p>The page you're looking for doesn't exist.</p>
      <RouteSuggestions server:defer>
        <div
          slot="fallback"
          class="route-suggestions"
          aria-busy="true"
          aria-live="polite"
        >
          <p>Looking for similar pages...</p>
          <ul aria-hidden="true">
            <li><span class="route-suggestions__skeleton-item" /></li>
            <li><span class="route-suggestions__skeleton-item" /></li>
            <li><span class="route-suggestions__skeleton-item" /></li>
            <li><span class="route-suggestions__skeleton-item" /></li>
            <li><span class="route-suggestions__skeleton-item" /></li>
          </ul>
        </div>
      </RouteSuggestions>
      <Button as="a" icon="arrow-right" href="/">
        Back to home
      </Button>
    </EmptyState>
  </Section>
</Base>
