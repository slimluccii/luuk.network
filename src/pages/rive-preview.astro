---
import Base from "~/layouts/Base.astro";
import Rive from "~/components/Rive.astro";
import wasmUrl from "@rive-app/canvas/rive.wasm?url";

const seo = {
  title: "Front-end Designer & Developer",
  description:
    "Cum laude graduate in Front-end Design & Development. I build accessible and performant web experiences. My work is guided by digital sovereignty, responsible AI, and managing complexity.",
};

const riveSrc = "https://cdn.rive.app/animations/vehicles.riv";
---

<Base seo={seo}>
  <Fragment slot="head">
    <link rel="preload" href={wasmUrl} as="fetch" crossorigin />
    <link rel="preload" href={riveSrc} as="fetch" crossorigin />
  </Fragment>
  <Rive src={riveSrc} stateMachines="bumpy" lazy={false} />
</Base>
