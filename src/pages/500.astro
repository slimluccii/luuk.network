---
import Base from "~/layouts/Base.astro";
import PageHeader from "~/components/PageHeader.astro";
import PageHeaderEyebrow from "~/components/PageHeaderEyebrow.astro";

const seo = {
  title: "Server error",
  description: "An unexpected error occurred.",
};
---

<Base seo={seo}>
  <article class="error-state">
    <PageHeader>
      <PageHeaderEyebrow>500</PageHeaderEyebrow>
      <h1 class="error-state__title">Server error</h1>
    </PageHeader>
    <div class="error-state__body">
      <p>Something went wrong on our end. Try again in a moment.</p>
    </div>
  </article>
</Base>

<style>
  .error-state {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-l);
    padding-block-end: var(--spacing-size-xxl);
  }

  .error-state__title {
    margin: 0;
    font-weight: 400;
    font-size: var(--typography-scale-heading);
    font-family: var(--typography-typeface-body);
  }

  .error-state__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-l);
    padding-inline: var(--spacing-size-l);
  }

  .error-state__body p {
    margin: 0;
  }
</style>
