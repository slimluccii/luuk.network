---
import Base from "~/layouts/Base.astro";

const seo = {
  title: "Server error",
  description: "An unexpected error occurred.",
};
---

<Base seo={seo}>
  <article class="error-state">
    <p class="error-state__code">500</p>
    <h1 class="error-state__title">Server error</h1>
    <p>Something went wrong on our end. Try again in a moment.</p>
  </article>
</Base>

<style>
  .error-state {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    padding: calc(var(--ln-header-height) + var(--spacing-size-xl))
      var(--spacing-size-l) var(--spacing-size-xxl);
  }

  .error-state__code {
    margin: 0;
    opacity: 0.5;
    font-size: var(--typography-scale-caption);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .error-state__title {
    margin: 0;
    font-weight: 400;
    font-size: var(--typography-scale-heading);
    font-family: var(--typography-typeface-body);
  }

  .error-state p {
    margin: 0;
  }
</style>
