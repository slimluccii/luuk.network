---
import type { ComponentProps } from "astro/types";
import Base from "~/layouts/Base.astro";
import PageHeader from "~/components/PageHeader.astro";
import PageHeaderEyebrow from "~/components/PageHeaderEyebrow.astro";
import { useTranslations } from "~/i18n";

const { t } = useTranslations((Astro.currentLocale ?? "en") as "en" | "nl");

const seoMetaTags: NonNullable<ComponentProps<typeof Base>["seoMetaTags"]> = [
  { tag: "title", content: t("server_error") },
];
---

<Base title={t("server_error")} seoMetaTags={seoMetaTags}>
  <article class="error-state">
    <PageHeader>
      <PageHeaderEyebrow>500</PageHeaderEyebrow>
      <h1 class="error-state__title">{t("server_error")}</h1>
    </PageHeader>
    <div class="error-state__body">
      <p>{t("server_error_body")}</p>
    </div>
  </article>
</Base>

<style>
  .error-state {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    padding-block-end: var(--spacing-size-xxl);
  }

  .error-state__title {
    margin: 0;
    font-weight: 400;
    font-size: var(--typography-scale-heading);
    font-family: var(--typography-typeface-body);
  }

  .error-state__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-m);
    padding-inline: var(--spacing-size-l);
  }

  .error-state__body p {
    margin: 0;
  }
</style>
