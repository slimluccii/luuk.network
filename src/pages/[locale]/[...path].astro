---
import type {
  GetStaticPaths,
  InferGetStaticParamsType,
  InferGetStaticPropsType
} from "astro";
import type {
  FooterQuery,
  FooterQueryVariables,
  SeoQuery,
  SeoQueryVariables,
  SiteLocale
} from "@generated/datocms";
import { getCollection } from "astro:content";
import { Base } from "@layouts";
import { Blocks } from "@components";
import { executeQuery } from "@datocms/execute-query";
import footerQuery from "@datocms/footer.query.graphql";
import seoQuery from "@datocms/seo.query.graphql";

export const getStaticPaths = (async () => {
  const pages = await getCollection("pages");
  return pages.map(({ id, data }) => {
    const [locale, ...pathArray] = id.split("/") as [SiteLocale, ...string[]];
    const path = pathArray.join("/");

    return {
      params: { locale, path: path.length > 0 ? path : undefined },
      props: { page: data }
    };
  });
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { locale } = Astro.params as Params;
const { page } = Astro.props as Props;

const { seo } = await executeQuery<SeoQuery, SeoQueryVariables>(seoQuery, {
  locale
});
const { footer } = await executeQuery<FooterQuery, FooterQueryVariables>(
  footerQuery,
  { locale }
);
---

<Base
  locale={locale}
  seo={[...seo.faviconMetaTags, ...page.seo]}
  footer={footer}
>
  <Blocks blocks={page.content} />
</Base>
