---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import PageLayout from "~/layouts/PageLayout.astro";
import PostLayout from "~/layouts/PostLayout.astro";
import ProjectLayout from "~/layouts/ProjectLayout.astro";

export const getStaticPaths = (async () => {
  const entries = await getCollection("pages");
  return entries.map((entry) => ({
    // `path` is the full locale-prefixed URL built by the loader; Astro rest
    // params can't carry a leading slash, so strip it at this boundary.
    params: { path: entry.data.path.replace(/^\//, "") },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const layouts = {
  page: PageLayout,
  post: PostLayout,
  project: ProjectLayout,
} as const;

const { entry } = Astro.props;
const modelApiKey = entry.data._modelApiKey;
const Layout = layouts[modelApiKey as keyof typeof layouts];
if (!Layout) {
  throw new Error(`Geen layout voor "${modelApiKey}"`);
}
---

<Layout entry={entry} />
