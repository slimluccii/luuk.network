---
import { Picture } from "astro:assets";
import Base from "~/layouts/Base.astro";
import Border from "~/components/Border.astro";
import Button from "~/components/Button.astro";

import image from "~/images/me.jpeg";

const seo = {
  title: "Front-end Designer & Developer",
  description:
    "Cum laude graduate in Front-end Design & Development. I build accessible and performant web experiences. My work is guided by digital sovereignty, responsible AI, and managing complexity.",
};
---

<Base seo={seo}>
  <Border class="hero">
    <div class="hero__visual"></div>
    <div class="hero__content">
      <div class="hero-content__top">
        <Picture
          class="hero__image"
          formats={["avif", "webp"]}
          widths={[200, 300, 400, 600]}
          sizes="(min-width: 600px) 200px, (min-width: 400px) 150px, 100px"
          src={image}
          alt=""
          loading="eager"
          fetchpriority="high"
        />

        <Button
          as="a"
          variant="secondary"
          icon="github"
          href="https://github.com/slimluccii">GitHub</Button
        >
      </div>

      <div class="hero-content__bottom">
        <h1 class="hero__title">Luuk Brauckmann</h1>
        <p>
          Cum laude graduate in Front-end Design & Development. I build
          accessible and performant web experiences. My work is guided by
          digital sovereignty, responsible AI, and managing complexity.
        </p>
      </div>
    </div>
  </Border>

  <Border>
    <section class="section">
      <h2>Now</h2>
      <p>Coming soon...</p>
    </section>
  </Border>

  <Border>
    <section class="section">
      <h2>Selected work</h2>
      <p>Coming soon...</p>
    </section>
  </Border>

  <Border>
    <section class="section">
      <h2>Recent writing</h2>
      <p>Coming soon...</p>
    </section>
  </Border>

  <Border>
    <section class="section">
      <h2>Principles</h2>
      <p>Coming soon...</p>
    </section>
  </Border>
</Base>

<style>
  .hero__visual {
    block-size: 100px;

    @media (min-width: 400px) {
      block-size: 150px;
    }

    @media (min-width: 600px) {
      block-size: 200px;
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-size-l);
    background-color: var(--color-surface-base);
    padding: var(--spacing-size-l) var(--spacing-size-l) var(--spacing-size-xxl);
  }

  .hero-content__top {
    display: flex;
    position: relative;
    justify-content: flex-end;
  }

  .hero__image {
    position: absolute;
    inset-block-end: 0px;
    inset-inline-start: 0px;
    inline-size: 100px;
    block-size: 100px;
    object-fit: cover;

    @media (min-width: 400px) {
      inline-size: 150px;
      block-size: 150px;
    }

    @media (min-width: 600px) {
      inline-size: 200px;
      block-size: 200px;
    }
  }

  .hero-content__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight);
  }

  .hero__title {
    font-size: var(--typography-scale-display);
  }

  .section {
    padding: var(--spacing-size-xxl) var(--spacing-size-l);
  }
</style>
