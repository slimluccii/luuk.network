---
import { getCollection } from "astro:content";
import Base from "~/layouts/Base.astro";
import Border from "~/components/Border.astro";
import Button from "~/components/Button.astro";
import Carousel from "~/components/Carousel.astro";
import Hero from "~/components/Hero.astro";
import Section from "~/components/Section.astro";
import SectionActions from "~/components/SectionActions.astro";
import SectionContent from "~/components/SectionContent.astro";
import SectionTitle from "~/components/SectionTitle.astro";

import image from "~/images/me.jpeg";

const seo = {
  title: "Front-end Designer & Developer",
  description:
    "Cum laude graduate in Front-end Design & Development. I build accessible and performant web experiences. My work is guided by digital sovereignty, responsible AI, and managing complexity.",
};

const selectedWork = (
  await getCollection("projects", ({ data }) => data.featured)
).sort((a, b) => a.data.order - b.data.order);

const workItems = selectedWork.map(({ id, data }) => ({
  href: `/projects/${id}/`,
  title: data.title,
  description: data.description,
  cover: data.cover,
}));
---

<Base seo={seo}>
  <Hero subject={image}>
    <Button
      slot="action"
      as="a"
      variant="secondary"
      icon="github"
      href="https://github.com/slimluccii">GitHub</Button
    >

    <h1 class="sr-only">Luuk Brauckmann, Front-end Designer & Developer</h1>
    <p class="hero__title" aria-hidden="true">Luuk Brauckmann</p>
    <p>
      Cum laude graduate in Front-end Design & Development. I build accessible
      and performant web experiences. My work is guided by digital sovereignty,
      responsible AI, and managing complexity.
    </p>
  </Hero>

  <Border>
    <Section>
      <SectionTitle>About</SectionTitle>
      <SectionContent>
        <p>
          I started studying Applicatie Ontwikkeling at MBO College Hilversum in
          2017. Two years in, I joined Simple Soft Products as an intern and
          stayed on part-time after, working on Angular apps for education,
          public services, and industrial software. I later went on to study
          Front-end Design & Development at Hogeschool van Amsterdam, graduating
          cum laude in 2024.
        </p>
        <p>
          Toward the end of my degree I joined De Voorhoede in Amsterdam as an
          intern, and stayed on after the internship ended. There I work on
          accessible websites, design systems, and open source tooling. The
          stack varies per project, and I enjoy moving between them.
        </p>
        <p>
          I believe in simple, standards-driven solutions. When picking tools, I
          aim for the least powerful one that does the job. My focus lies
          increasingly on digital sovereignty and an open, European web.
        </p>
      </SectionContent>
    </Section>
  </Border>

  <Border>
    <Section>
      <SectionTitle>Selected work</SectionTitle>
      <Carousel items={workItems} />
      <SectionActions>
        <Button as="a" icon="arrow-right" href="/projects/">
          See all projects
        </Button>
      </SectionActions>
    </Section>
  </Border>
</Base>
