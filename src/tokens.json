{
  "Fluid": {
    "Typography": {
      "$type": "fluid-scale",
      "$value": {
        "min": { "width": "320px", "size": "1rem", "scale": 1.333 },
        "max": { "width": "800px", "size": "1.125rem", "scale": 1.5 }
      }
    },
    "Spacing": {
      "$type": "fluid-scale",
      "$value": {
        "min": { "width": "320px", "size": "1.375rem", "scale": 1.618 },
        "max": { "width": "800px", "size": "1.5rem", "scale": 1.618 }
      }
    }
  },
  "Motion": {
    "Feedback": {
      "$type": "duration",
      "$value": "0.162s"
    },
    "Transition": {
      "$type": "duration",
      "$value": "0.262s"
    },
    "Emphasis": {
      "$type": "duration",
      "$value": "0.424s"
    }
  },
  "Opacity": {
    "Muted": {
      "$type": "number",
      "$value": "0.75"
    },
    "Subdued": {
      "$type": "number",
      "$value": "0.4"
    },
    "Subtle": {
      "$type": "number",
      "$value": "0.25"
    },
    "Faint": {
      "$type": "number",
      "$value": "0.1"
    }
  },
  "Typography": {
    "Typeface": {
      "Heading": {
        "$type": "string",
        "$value": "\"Dash Casual\", system-ui, serif"
      },
      "Body": {
        "$type": "string",
        "$value": "\"Source Sans\", system-ui, sans-serif"
      }
    },
    "Scale": {
      "Caption": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Typography}", "step": -1 }
      },
      "Body": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Typography}", "step": 0 }
      },
      "Subtitle": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Typography}", "step": 1 }
      },
      "Heading": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Typography}", "step": 2 }
      },
      "Display": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Typography}", "step": 3 }
      }
    }
  },
  "Spacing": {
    "Size": {
      "XXS": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": -3 }
      },
      "XS": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": -2 }
      },
      "S": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": -1 }
      },
      "M": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": 0 }
      },
      "L": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": 1 }
      },
      "XL": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": 2 }
      },
      "XXL": {
        "$type": "fluid-size",
        "$value": { "scale": "{Fluid.Spacing}", "step": 3 }
      }
    },
    "Inset": {
      "Compact": {
        "$type": "dimension",
        "$value": "{Spacing.Size.S}"
      },
      "Comfortable": {
        "$type": "dimension",
        "$value": "{Spacing.Size.M}"
      },
      "Loose": {
        "$type": "dimension",
        "$value": "{Spacing.Size.L}"
      }
    },
    "Gap": {
      "Tight": {
        "$type": "dimension",
        "$value": "{Spacing.Size.XS}"
      },
      "Regular": {
        "$type": "dimension",
        "$value": "{Spacing.Size.S}"
      },
      "Spacious": {
        "$type": "dimension",
        "$value": "{Spacing.Size.M}"
      }
    }
  },
  "Color": {
    "Intent": {
      "Critical": {
        "$type": "color",
        "$value": "#FF5B58"
      },
      "Success": {
        "$type": "color",
        "$value": "#1FA47C"
      },
      "Caution": {
        "$type": "color",
        "$value": "#FFB741"
      },
      "Informative": {
        "$type": "color",
        "$value": "#E34989"
      }
    },
    "Brand": {
      "Primary": {
        "$type": "color",
        "$value": "#009EFF"
      },
      "Secondary": {
        "$type": "color",
        "$value": "#E6EAF5"
      },
      "Accent": {
        "$type": "color",
        "$value": "#FF6200"
      },
      "Highlight": {
        "$type": "color",
        "$value": "#FFD166"
      },
      "Neutral": {
        "$type": "color",
        "$value": "#1B263B"
      }
    },
    "Surface": {
      "Canvas": {
        "$type": "color",
        "$value": "#001523"
      },
      "Base": {
        "$type": "color",
        "$value": "{Color.Brand.Neutral}"
      },
      "Raised": {
        "$type": "color",
        "$value": "#415A77"
      },
      "Overlay": {
        "$type": "color",
        "$value": "#0A2A3E"
      }
    }
  }
}
